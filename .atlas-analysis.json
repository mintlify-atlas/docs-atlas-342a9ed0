  "keyFeatures": [
    "Simple and powerful abstractions with atom, computed, action, and effect primitives",
    "Explicit reactivity without proxies for predictable state management",
    "Perfect effects management with async handling, caching, retrying, and automatic cancellation",
    "Excellent debugging experience with built-in logging and immutable cause tracking",
    "Composable extensions for async operations, persistence, caching, and more",
    "Framework-agnostic with adapters for React, Vue, Preact, Solid, and Lit",
    "Smallest bundle size at 2 KB gzipped for core",
    "Best TypeScript experience with top type inference and type safety"
  ],
